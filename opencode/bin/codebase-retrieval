#!/usr/bin/env bash
# Search the codebase index for semantically similar code chunks.
#
# Usage:
#   codebase-retrieval "<query>"                        # search current repo
#   codebase-retrieval "<query>" --workspace <path>     # search a specific repo
#   codebase-retrieval "<query>" --no-refresh           # skip incremental re-index
#   codebase-retrieval "<query>" --limit <n>            # limit results
#
# When --workspace is not provided, $PWD is injected automatically so results
# are scoped to the repository you are currently working in.
#
# All flags are forwarded verbatim to:
#   bun run codebase-retrieval <query> [flags]
#
# Requires AI_CODING_MONOREPO to be set (done globally by Home Manager).

set -euo pipefail

# Resolve bun — probe common install locations before falling back to PATH.
# Covers: default bun installer (~/.bun), Nix user/system profiles, system paths.
_bun="bun"
for _candidate in "$HOME/.bun/bin/bun" "$HOME/.nix-profile/bin/bun" "/nix/var/nix/profiles/default/bin/bun" "/usr/local/bin/bun" "/usr/bin/bun"; do
  [ -x "$_candidate" ] && _bun="$_candidate" && break
done

monorepo="${AI_CODING_MONOREPO:?AI_CODING_MONOREPO is not set — run: home-manager switch}"

# If --workspace is already provided, forward everything as-is
for arg in "$@"; do
  if [[ "$arg" == "--workspace" ]]; then
    exec "$_bun" run --cwd "$monorepo" codebase-retrieval "$@"
  fi
done

# Otherwise inject --workspace $PWD so results are scoped to the current repo
exec "$_bun" run --cwd "$monorepo" codebase-retrieval "$@" --workspace "$PWD"
